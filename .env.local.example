# Database
DATABASE_URL=postgresql://user:password@localhost:5432/ajax_dev
POSTGRES_PRISMA_URL=postgresql://user:password@localhost:5432/ajax_dev?schema=public
POSTGRES_URL_NON_POOLING=postgresql://user:password@localhost:5432/ajax_dev?schema=public

# Supabase (if using Supabase)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic API for Claude
ANTHROPIC_API_KEY=sk-ant-v0-xxx

# Revalidation & Webhooks
REVALIDATE_SECRET=your-secret-key-here
ISR_REVALIDATION_TOKEN=your-token-here

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Optional: Vercel
VERCEL_URL=http://localhost:3000
VERCEL_TOKEN=your-vercel-token
VERCEL_ORG_ID=your-org-id
VERCEL_PROJECT_ID=your-project-id
