// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model Person {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug      String   @unique
  fullName  String   @map("full_name")
  ward      String?
  photoUrl  String?  @map("photo_url")
  email     String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  roles      Role[]
  votes      Vote[]
  donations  Donation[]

  @@map("persons")
}

model Election {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  year          Int
  electionDate  Date?    @map("election_date")
  status        String   @default("closed") // closed | upcoming | active
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  roles     Role[]
  donations Donation[]

  @@map("elections")
}

model Role {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  personId    String   @map("person_id") @db.Uuid
  electionId  String?  @map("election_id") @db.Uuid
  title       String
  ward        String?
  won         Boolean  @default(false)
  votesReceived Int?   @map("votes_received")
  votePct     Decimal? @db.Numeric(5, 2) @map("vote_pct")
  startDate   Date?    @map("start_date")
  endDate     Date?    @map("end_date") // NULL means currently serving

  person    Person    @relation(fields: [personId], references: [id])
  election  Election? @relation(fields: [electionId], references: [id])

  @@map("roles")
}

model Meeting {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  meetingDate Date     @map("meeting_date")
  committee   String   // Council | GGC | CAPC
  sourceUrl   String?  @map("source_url")
  pdfUrl      String?  @map("pdf_url")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  motions Motion[]

  @@map("meetings")
}

model Motion {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  meetingId String   @map("meeting_id") @db.Uuid
  sequence  Int
  title     String
  fullText  String?  @map("full_text")
  outcome   String?  // CARRIED | LOST

  meeting Meeting @relation(fields: [meetingId], references: [id])
  votes   Vote[]

  @@map("motions")
}

model Vote {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  motionId  String   @map("motion_id") @db.Uuid
  personId  String   @map("person_id") @db.Uuid
  position  String   // for | against | absent

  motion Motion @relation(fields: [motionId], references: [id])
  person Person @relation(fields: [personId], references: [id])

  @@map("votes")
}

model Donation {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  personId     String   @map("person_id") @db.Uuid
  electionId   String?  @map("election_id") @db.Uuid
  donorName    String   @map("donor_name")
  donorAddress String?  @map("donor_address")
  amountCents  Int      @map("amount_cents")
  source       String?  // PDF filename for traceability

  person    Person    @relation(fields: [personId], references: [id])
  election  Election? @relation(fields: [electionId], references: [id])

  @@map("donations")
}

model ScrapeLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sourceUrl   String   @map("source_url")
  contentHash String   @unique @map("content_hash")
  scrapedAt   DateTime @default(now()) @map("scraped_at") @db.Timestamptz(6)
  status      String?  // success | error | skipped

  @@map("scrape_log")
}
